{
  "permissions": {
    "allow": [
      "Bash",
      "WebSearch",
      "WebFetch",
      "Read",
      "Edit",
      "Write",
      "LS",
      "Grep",
      "Glob",
      "MultiEdit",
      "Task",
      "mcp__*"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout .:*)",
      "Bash(git clean:*)"
    ]
  },
  "defaultMode": "acceptEdits",
  "skipDangerousModePermissionPrompt": true,

  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel)\" && CHANGED=$(git diff --name-only -- \"*.ts\" \"*.tsx\" 2>/dev/null); if [ -n \"$CHANGED\" ]; then echo \"Running typecheck...\"; npx tsc --noEmit 2>&1 | tail -30; fi'"
          }
        ]
      }
    ]
  }
}
