{
  "name": "reply-flow",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:client --workspace=client\" \"npm run dev:backend --workspace=server\"",
    "dev:client": "npm run dev:client --workspace=client",
    "dev:server": "npm run dev:backend --workspace=server",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "build:client": "npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "start": "npm run start --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
